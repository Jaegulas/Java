
public class Opr07 {

	public static void main(String[] args) {
		
		int a = 10, b = 10;
		
		//변수 a의 값을 1올리기
		//해석 : 변수 a의 값에 1을 더해서 다시 a변수에 저장
		++a; 
		System.out.println("a의 값 = " + a); //11
		
		//변수 b의 값을 1내리기
		//해석 : 변수 b의 값에 1을 빼서 다시 b변수에 저장
		--b;
		System.out.println("b의 값 = " + b); //9 

	}

}
