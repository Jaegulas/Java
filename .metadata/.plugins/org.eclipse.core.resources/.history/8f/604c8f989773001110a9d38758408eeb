
public class Opr08 {

	public static void main(String[] args) {
		
		int a = 10, b = 10; 
		
		/* ++증가연산자가 변수명b 뒤에 붙으면 후행처리 이므로 b변수값 10을 먼저 출력후에 
		   b변수에 저장된 값을 1증가 하여 11로 만듭니다 */
		System.out.println(b++); //10먼저 출력 후 b++통해 b변수의 값을 1증가 시켜 11로 만듬
		System.out.println(b);   //1증가 된 b변수값 11출력
		
		/*
		 	++ 증가연산자가 변수명a 앞에 붙으면 선행처리 이므로 a변수값이 1증가된 후에
		 	출력되어 11이 출력됩니다.
		*/
		System.out.println(++a); 
		// 다시 한번더 a변수값 출력해도 11이 출력됩니다.
		System.out.println(a);
		
		a=b=10;

	}

}
